# Variables d'environnement publiques pour Vite
# Ces variables sont exposées côté client (c'est normal pour EmailJS)
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs

# EmailJS Configuration
# Récupérez ces valeurs depuis https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
